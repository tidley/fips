+pub(super) fn allow_in_rate_window(
+    windows: &mut RateLimitWindow,
+    key: &str,
+    now: u64,
+    window_ms: u64,
+    max_requests: usize,
+) -> bool {
+    if max_requests == 0 {
+        return false;
+    }
+    let entry = windows.entry(key.to_string()).or_default();
+    entry.retain(|timestamp| now.saturating_sub(*timestamp) <= window_ms);
+    if entry.len() >= max_requests {
+        return false;
+    }
+    entry.push(now);
+    true
+}
