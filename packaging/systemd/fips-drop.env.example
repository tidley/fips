# Optional environment overrides for fips-drop.service.
#
# Install as:
#   sudo install -m 0644 packaging/systemd/fips-drop.env.example /etc/default/fips-drop

FIPS_DROP_CONFIG=/etc/fips/fips.yaml
FIPS_DROP_STORAGE_ROOT=/var/lib/fips-drop
FIPS_DROP_PORT=4242

# Uncomment for packet-level troubleshooting.
# RUST_LOG=debug,fips::discovery::nostr=trace
